# Copy this file to .env and fill in values.
# Never commit .env to version control.

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: start TimescaleDB with `docker compose -f docker/docker-compose.yml up timescaledb`
DATABASE_URL=postgresql+asyncpg://pulse:pulse@localhost:5432/pulse

# ── NanoClaw agent authentication ─────────────────────────────────────────────
# Protects the /agent/* endpoints. Set to a strong random string in production.
AGENT_API_KEY=dev-key-change-me

# ── Web ───────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
